# Server Configuration
PORT=5000
NODE_ENV=development

# Database - Use MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/database-name?retryWrites=true&w=majority

# JWT Authentication - Use a strong secret key
JWT_SECRET=your-super-secure-random-secret-key-min-32-characters

# Optional: External API Keys (add when needed)
# SMS_API_KEY=
# SMS_API_SECRET=
# POLICE_API_KEY=
# IECMS_API_KEY=
